# ========================================================
# UDATA FE MARKETING - MẪU FILE BIẾN MÔI TRƯỜNG (.env)
# 
# Lưu ý: 
# - Khi deploy dự án, copy nội dung file này vào file `.env`
# - KHÔNG commit file `.env` chứa dữ liệu nhạy cảm lên Github.
# ========================================================

# Môi trường chạy của ứng dụng (development | production)
NODE_ENV=development

# URL của Backend API (Nếu web cần gọi API)
# VD: https://api.udata.ai
VITE_API_BASE_URL=

# Port mặc định khi chạy local
PORT=5173
